# Env for docker-compose.deploy.yml (shared-VPS deploy, pulls images from GHCR,
# attaches to the existing treklink-edge Traefik). Copy to .env.production on the
# VPS and fill real values:
#   cp .env.production.deploy.example .env.production   # then edit
#
# Compose does NOT expand ${...} inside this file — write literal values.
# Quote values with special chars ($ ` etc.).

# ─── Images (GHCR — pull prebuilt) ───────────────────────────────────────────
# Full image = ${REGISTRY}/${IMAGE_NAMESPACE}/web:${IMAGE_TAG}  (and /worker, /landing)
# IMAGE_TAG should be the git short SHA you built & pushed (not just 'latest').
REGISTRY=ghcr.io
IMAGE_NAMESPACE=leducanhphuong/github-pr-code-smell-detector
IMAGE_TAG=latest

# ─── Public domains ──────────────────────────────────────────────────────────
# Each must have an A record pointing at the VPS IP (103.75.185.68) so the edge
# Traefik can issue a Let's Encrypt cert. TLS is handled by the shared edge —
# no ACME_EMAIL needed here (edge already configured with the `letsencrypt` resolver).
#   app.mergetrack.site → dashboard (web)   — A record
#   mergetrack.site + www     → landing            — A records (apex + www)
DOMAIN=app.mergetrack.site
LANDING_DOMAIN=mergetrack.site

# ─── Postgres (this project's OWN db — internal only, not published) ──────────
POSTGRES_USER=mergetrack
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=code_smell_db

# Must match the Postgres creds above. Host = compose service name `postgres`.
DATABASE_URL=postgresql://mergetrack:change-me-strong-password@postgres:5432/code_smell_db?schema=public

# ─── Redis / BullMQ (this project's OWN redis — internal service `redis`) ─────
REDIS_URL=redis://redis:6379

# ─── Auth.js session secret ──────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=

# ─── GitHub OAuth App (user login) ───────────────────────────────────────────
# Homepage URL:            https://app.mergetrack.site
# Authorization callback:  https://app.mergetrack.site/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# ─── GitHub App (PR comment bot — Luồng B) ───────────────────────────────────
# Webhook URL: https://app.mergetrack.site/api/webhooks/github
# Setup URL:   https://app.mergetrack.site/api/github/setup
GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_WEBHOOK_SECRET=
# Private key (.pem). One line with literal \n, or a quoted multi-line value.
GITHUB_APP_PRIVATE_KEY=
