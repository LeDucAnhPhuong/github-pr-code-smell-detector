# Production env for docker-compose.prod.yml.
#   cp .env.production.example .env.production   # then fill in real values
#   docker compose -f docker-compose.prod.yml --env-file .env.production up -d --build
#
# NOTE: values with special characters ($ ` etc.) should be quoted. Compose does
# NOT expand ${...} inside this file — write literal values.

# ─── Image refs (only for docker-compose.deploy.yml — pull prebuilt images) ──
# Set these to whatever you tagged & pushed from your dev machine.
# Docker Hub example: WEB_IMAGE=youruser/csd-web:1.0.0
# GHCR example:       WEB_IMAGE=ghcr.io/youruser/csd-web:1.0.0
WEB_IMAGE=youruser/csd-web:latest
WORKER_IMAGE=youruser/csd-worker:latest

# ─── Domain & TLS ────────────────────────────────────────────────────────────
# Both must point (A/AAAA record) at this server's IP.
#   DOMAIN         → dashboard (web)
#   LANDING_DOMAIN → landing (apex); the landing router also serves www.<apex>
#   ADMIN_DOMAIN   → admin panel
DOMAIN=app.mergetrack.site
LANDING_DOMAIN=mergetrack.site
ADMIN_DOMAIN=admin.mergetrack.site
# Email Let's Encrypt uses for expiry notices.
ACME_EMAIL=you@example.com

# ─── Postgres (internal only — not published to the host) ────────────────────
POSTGRES_USER=csd
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=code_smell_db

# Must match the Postgres creds above. Host is the compose service name `postgres`.
DATABASE_URL=postgresql://csd:change-me-strong-password@postgres:5432/code_smell_db?schema=public

# ─── Redis / BullMQ (internal service name `redis`) ──────────────────────────
REDIS_URL=redis://redis:6379

# ─── Auth.js session secret ──────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=

# ─── GitHub OAuth App (dashboard user login) ─────────────────────────────────
# Homepage URL:            https://app.mergetrack.site
# Authorization callback:  https://app.mergetrack.site/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# ─── GitHub OAuth App (ADMIN login — SEPARATE app) ───────────────────────────
# A classic OAuth App allows only ONE callback URL, so admin needs its own app.
# Homepage URL:            https://admin.mergetrack.site
# Authorization callback:  https://admin.mergetrack.site/api/auth/callback/github
ADMIN_AUTH_GITHUB_ID=
ADMIN_AUTH_GITHUB_SECRET=

# ─── GitHub App (PR comment bot — Luồng B) ───────────────────────────────────
# Webhook URL: https://app.mergetrack.site/api/webhooks/github
# Setup URL:   https://app.mergetrack.site/api/github/setup
GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_WEBHOOK_SECRET=
# Private key (.pem). One line with literal \n, or a quoted multi-line value.
GITHUB_APP_PRIVATE_KEY=

# ─── OpenRouter (LLM: Project Overview indexing + PR analysis) ───────────────
# REQUIRED for LLM jobs. Get a key at https://openrouter.ai/keys
# NOTE: compose does NOT expand ${...}; JSON has no $ or # so leave it unquoted.
OPENROUTER_API_KEY=
# Model map (primary + fallback per purpose) — the models currently selected in code.
OPENROUTER_MODEL_MAP={"overview_map":["deepseek/deepseek-v3.2","openai/gpt-5-mini"],"overview_reduce":["openai/gpt-5","anthropic/claude-sonnet-4.6"],"pr_map":["openai/gpt-5-mini","anthropic/claude-haiku-4.5"],"pr_reduce":["anthropic/claude-sonnet-4.6","openai/gpt-5"]}
# Per-purpose output token caps.
OPENROUTER_MAX_TOKENS={"overview_map":512,"overview_reduce":6000,"pr_map":1500,"pr_reduce":800}
# Attribution headers (optional).
OPENROUTER_APP_URL=https://app.mergetrack.site
OPENROUTER_APP_TITLE=MergeTrack

# ─── SePay (VietQR bank-transfer payments) ───────────────────────────────────
# Webhook URL to configure in SePay dashboard:
#   https://app.mergetrack.site/api/webhooks/sepay   (Auth: Apikey)
# The Apikey value you set on the SePay webhook (Authorization: Apikey <key>).
SEPAY_WEBHOOK_API_KEY=
# The bank account linked in SePay that receives transfers.
SEPAY_BANK_ACCOUNT=
# Bank short code for VietQR, e.g. ACB, MBBank, Vietcombank, TPBank.
SEPAY_BANK_CODE=
# Account holder name (shown on the checkout page; optional).
SEPAY_ACCOUNT_NAME=
