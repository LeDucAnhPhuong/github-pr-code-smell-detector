{
  "name": "github-pr-code-smell-detector-monorepo",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "dev": "concurrently -k -n dashboard,admin,worker -c green,cyan,magenta \"npm run dev -w packages/dashboard\" \"npm run dev -w packages/admin\" \"npm run worker -w packages/dashboard\"",
    "dev:apps": "concurrently -k -n analyzer,dashboard -c blue,green \"npm run dev -w packages/analyzer\" \"npm run dev -w packages/dashboard\"",
    "dev:dashboard": "npm run dev -w packages/dashboard",
    "dev:admin": "npm run dev -w packages/admin",
    "dev:landing": "npm run dev -w packages/landing",
    "dev:worker": "npm run worker -w packages/dashboard",
    "db:up": "docker compose -f packages/dashboard/docker-compose.yml up -d",
    "db:down": "docker compose -f packages/dashboard/docker-compose.yml down",
    "db:generate": "npm run db:generate -w packages/core",
    "db:migrate": "npm run db:migrate -w packages/core",
    "db:seed": "npm run db:seed -w packages/core",
    "db:studio": "npm run db:studio -w packages/core"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
