{
  "name": "github-pr-code-smell-detector-monorepo",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "dev": "concurrently -k -n analyzer,dashboard,worker -c blue,green,magenta \"npm run dev -w packages/analyzer\" \"npm run dev -w packages/dashboard\" \"npm run worker -w packages/dashboard\"",
    "dev:apps": "concurrently -k -n analyzer,dashboard -c blue,green \"npm run dev -w packages/analyzer\" \"npm run dev -w packages/dashboard\"",
    "dev:dashboard": "npm run dev -w packages/dashboard",
    "dev:landing": "npm run dev -w packages/landing",
    "dev:worker": "npm run worker -w packages/dashboard",
    "db:up": "docker compose -f packages/dashboard/docker-compose.yml up -d",
    "db:down": "docker compose -f packages/dashboard/docker-compose.yml down"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
