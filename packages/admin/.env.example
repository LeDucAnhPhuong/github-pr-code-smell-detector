# Admin app (port 3002) — has its OWN GitHub login (independent of dashboard).

# Same database as the dashboard (shared users/sessions).
DATABASE_URL=postgresql://csd:csd@localhost:5433/code_smell_db?schema=public

# Must match the dashboard so a session created by either app stays valid.
NEXTAUTH_SECRET=

# Auth.js base URL for THIS app, so the GitHub OAuth callback resolves to :3002.
AUTH_URL=http://localhost:3002

# GitHub OAuth App credentials for ADMIN.
# IMPORTANT: a classic GitHub OAuth App allows only ONE callback URL, so the
# admin app needs its OWN OAuth App (separate from the dashboard's), with
# Authorization callback URL = http://localhost:3002/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Link back to the dashboard (shown in the admin user menu).
DASHBOARD_URL=http://localhost:3000
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3000
