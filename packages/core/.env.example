# Copy to .env and fill in. Defaults below match docker-compose.yml.

# Database — Docker Postgres is published on host port 5433 (see docker-compose.yml)
DATABASE_URL="postgresql://csd:csd@localhost:5433/code_smell_db?schema=public"

# Redis / BullMQ — Docker Redis on 6379
REDIS_URL="redis://localhost:6379"

# Auth.js session secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# GitHub OAuth App (https://github.com/settings/developers)
#   Callback URL: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# ─── GitHub App (PR comment bot — Luồng B) ───────────────────────────────────
# Register at: https://github.com/settings/apps
#   Permissions: Contents(R), Pull requests(RW), Checks(RW), Metadata(R)
#   Events: Pull request, Installation, Installation repositories
#   Webhook URL: http://localhost:3000/api/webhooks/github (dùng smee/ngrok khi dev)
#   Setup URL:   http://localhost:3000/api/github/setup
GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
# Webhook signature secret of the App (thay cho GITHUB_WEBHOOK_SECRET cũ)
GITHUB_APP_WEBHOOK_SECRET=
# Private key (.pem). Một dòng với \n, hoặc dán nhiều dòng giữa cặp ngoặc kép.
GITHUB_APP_PRIVATE_KEY=

# (Legacy) webhook secret cho cơ chế webhook thủ công cũ — không còn dùng với GitHub App
GITHUB_WEBHOOK_SECRET=
